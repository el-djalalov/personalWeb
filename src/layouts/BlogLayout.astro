---
import type { CollectionEntry } from "astro:content";
import { SITE } from "@/config";
import { useTranslations } from "@/i18n/ui";
import AITranslator from "@/components/blog/AITranslator";
import LanguageSwitcher from "@/components/blog/LanguageSwitcher";
import getReadingTime from "@/utils/getReadingTime";
import BlogHeader from "@/components/blog/BlogHeader.astro";
import "@/styles/globals.css";

interface Props {
  post: CollectionEntry<"blog">;
  content: string;
}

const { post, content } = Astro.props;
const { data } = post;

const t = useTranslations("en");
const readingTime = getReadingTime(content);

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(data.pubDatetime);

const formattedModDate = data.modDatetime
  ? new Intl.DateTimeFormat("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(data.modDatetime)
  : null;

// Get OG image URL - handle both string URLs and image objects
const ogImageUrl = data.ogImage
  ? (typeof data.ogImage === 'string' ? data.ogImage : data.ogImage.src)
  : `${SITE.website}${SITE.ogImage}`;
---

<!doctype html>
<html lang={data.lang || "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{data.title} | {SITE.title}</title>
    <meta name="title" content={`${data.title} | ${SITE.title}`} />
    <meta name="description" content={data.description} />
    <meta name="author" content={data.author || SITE.author} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:title" content={data.title} />
    <meta property="og:description" content={data.description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="article:published_time" content={data.pubDatetime.toISOString()} />
    {data.modDatetime && <meta property="article:modified_time" content={data.modDatetime.toISOString()} />}
    <meta property="article:author" content={data.author || SITE.author} />
    {data.tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="twitter:title" content={data.title} />
    <meta property="twitter:description" content={data.description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <!-- Canonical URL -->
    <link rel="canonical" href={data.canonicalURL || new URL(Astro.url.pathname, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="antialiased bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <!-- Blog Header with Theme Toggle -->
    <BlogHeader backLink="/blog" backText="Back to Blog" />

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

      <!-- Article Header -->
      <article>
        <header class="mb-8">
          <div class="flex justify-between items-start mb-4 gap-4">
            <h1 class="text-4xl sm:text-5xl font-bold bg-gradient-to-r from-cyan-900 via-fuchsia-800 to-blue-700 dark:from-cyan-400 dark:via-fuchsia-400 dark:to-blue-400 bg-clip-text text-transparent">
              {data.title}
            </h1>
            <LanguageSwitcher client:load currentLang={data.lang || "en"} />
          </div>

          <p class="text-xl text-gray-600 dark:text-gray-400 mb-4">
            {data.description}
          </p>

          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span>{data.author || SITE.author}</span>
            </div>

            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time datetime={data.pubDatetime.toISOString()}>
                {formattedDate}
              </time>
            </div>

            {formattedModDate && (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <span>Updated {formattedModDate}</span>
              </div>
            )}

            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{readingTime} min read</span>
            </div>
          </div>

          <!-- Tags -->
          {data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {data.tags.map(tag => (
                <a
                  href={`/blog/tags/${tag.toLowerCase()}`}
                  class="px-3 py-1 text-sm bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-full transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </header>

        <!-- Translation Controls -->
        <div class="mb-8">
          <AITranslator
            client:load
            sourceLang={data.lang || "en"}
            targetLang={data.lang === "uz" ? "en" : "uz"}
            targetLangName={data.lang === "uz" ? "English" : "O'zbek"}
          />
        </div>

        <!-- Blog Content -->
        <div id="blog-content" class="prose prose-lg dark:prose-invert max-w-none">
          <slot />
        </div>

        <!-- Edit Post Link -->
        {SITE.editPost && SITE.editPost.url && (
          <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
            <a
              href={`${SITE.editPost.url}${SITE.editPost.appendFilePath ? `/${post.id}` : ""}`}
              class="inline-flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              <span>{SITE.editPost.text || "Edit this post"}</span>
            </a>
          </div>
        )}
      </article>
    </main>
  </body>
</html>
